# Jellyfin Media Copy Configuration
# Copy this file to config.yaml and fill in your values

pi:
  host: "192.168.1.100"      # Raspberry Pi IP address
  user: "pi"                  # SSH username
  # Use either password or key_path (key_path is more secure)
  password: null              # SSH password (null if using key)
  key_path: "~/.ssh/id_rsa"   # SSH private key path (null if using password)
  port: 22                    # SSH port
  sudo_password: null         # Sudo password for update mode (required for Maintenance mode)

paths:
  downloads: "/mnt/storage/downloads"           # qBittorrent download directory
  jellyfin_shows: "/mnt/media/Shows"           # Jellyfin TV shows directory
  jellyfin_movies: "/mnt/media/Movies"         # Jellyfin movies directory
  local_destination: "./downloads"              # Local destination for external copy mode (Pi → Laptop)

options:
  dry_run: false              # Set to true to preview without copying
  bwlimit: null               # Bandwidth limit in KB/s (null for unlimited)
  preserve_permissions: true  # Preserve file permissions with rsync

jellyfin:
  host: "192.168.1.174"       # Jellyfin server host (usually same as Pi)
  port: 8096                  # Jellyfin web interface port
  api_key: null               # Jellyfin API key for library refresh (optional)
                              # Get from Jellyfin: Dashboard → Advanced → API Keys

# Telegram Bot Configuration (optional)
# Run the bot on your Pi with: python telegram_bot.py
telegram:
  token: "YOUR_BOT_TOKEN_HERE"  # Get from @BotFather on Telegram
  allowed_users: []             # List of allowed Telegram user IDs (empty = allow all)
                                # Use /start to see your user ID if unauthorized

# WiFi Monitor Configuration (optional)
# Monitors WiFi connectivity and reconnects if needed
wifi:
  enabled: true                  # Set to false to disable WiFi monitoring
  check_host: "8.8.8.8"         # Host to ping for connectivity check
  check_timeout: 5              # Ping timeout in seconds
  restart_manager: true           # Restart NetworkManager on failure
  # Primary WiFi to connect to when reconnecting
  primary_ssid: "YourPrimaryWiFi"
  primary_password: null          # Password for primary WiFi (optional if saved in NetworkManager)
  # Fallback WiFi if primary is unavailable
  fallback_ssid: "YourFallbackWiFi"
  fallback_password: null         # Password for fallback WiFi (optional)

